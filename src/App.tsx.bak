import {
  Activity,
  ArrowRight,
  Banknote,
  BarChart3,
  BookOpen,
  Bot,
  BriefcaseBusiness,
  Building2,
  Check,
  ChevronDown,
  Clock3,
  Code2,
  Copy,
  Download,
  FileText,
  Headphones,
  Home,
  Layers3,
  LockKeyhole,
  LogOut,
  Mail,
  Menu,
  Mic2,
  Pause,
  Network,
  Play,
  Radio,
  Search,
  Settings,
  ShieldCheck,
  SlidersHorizontal,
  Sparkles,
  Upload,
  Users,
  Volume2,
  X,
  Zap,
} from "lucide-react";
import { ReactNode, useEffect, useState } from "react";

type DashboardTab = "overview" | "voice" | "models" | "history" | "settings";
type MarketingPage = "home" | "docs" | "about" | "blog";
type ClonedVoice = {
  id: string;
  name: string;
  sampleFileName: string;
  audioBase64: string;
  createdAt: string;
};
type UploadedVoice = {
  audio_base64: string;
  filename: string;
};
type GeneratedVoice = {
  id: string;
  title: string;
  model: string;
  voice: string;
  duration: string;
  status: "Ready" | "Processing";
  createdAt: string;
};
type AudioGenerationResponse = {
  audio_url?: string;
  audioUrl?: string;
  url?: string;
  file_url?: string;
  fileUrl?: string;
  audio_base64?: string;
  audioBase64?: string;
  audio?: string;
};
type EmotionListResponse =
  | string[]
  | {
      emotions?: string[];
      data?: string[];
      results?: string[];
    };
type GoogleCredentialResponse = {
  credential?: string;
};
type GoogleAuthResponse = {
  access_token?: string;
  token?: string;
  user?: unknown;
};
type GoogleProfile = {
  email?: string;
  name?: string;
  picture?: string;
  sub?: string;
};

declare global {
  interface Window {
    google?: {
      accounts: {
        id: {
          initialize: (options: {
            client_id: string;
            callback: (response: GoogleCredentialResponse) => void;
          }) => void;
          prompt: (callback?: (notification: {
            isNotDisplayed: () => boolean;
            isSkippedMoment: () => boolean;
            getNotDisplayedReason: () => string;
            getSkippedReason: () => string;
          }) => void) => void;
        };
      };
    };
  }
}

type NavDropdown = {
  label: string;
  items: { label: string; href: string }[];
};

const modelItems = [
  { label: "Emotion Model", href: "#emotion-model" },
  { label: "No Emotion Model", href: "#no-emotion-model" },
];

const resourceItems = [
  { label: "Docs", href: "/docs" },
  { label: "About", href: "/about" },
  { label: "Blog", href: "/blog" },
];

const codeSample = `const response = await paysys.voice.generate({
  model: "emotion-voice-v1",
  voice: "nora-enterprise",
  format: "wav_stream",
  text: "Welcome back. Your secure voice experience is ready."
});

for await (const chunk of response.audio) {
  player.write(chunk);
}`;

function App() {
  const [menuOpen, setMenuOpen] = useState(false);
  const [signinOpen, setSigninOpen] = useState(false);
  const [isSignedIn, setIsSignedIn] = useState(false);
  const [page, setPage] = useState<MarketingPage>(() => getPageFromPath());

  useEffect(() => {
    const handlePopState = () => setPage(getPageFromPath());
    window.addEventListener("popstate", handlePopState);
    return () => window.removeEventListener("popstate", handlePopState);
  }, []);

  const scrollTo = (id: string) => {
    const node = document.querySelector(id);
    if (node) node.scrollIntoView({ behavior: "smooth", block: "start" });
    window.history.pushState(null, "", id);
    setMenuOpen(false);
  };

  const openSignin = () => {
    setSigninOpen(true);
    setMenuOpen(false);
  };

  const openPage = (nextPage: MarketingPage) => {
    setPage(nextPage);
    setMenuOpen(false);
    const url = nextPage === "home" ? "/" : `/${nextPage}`;
    window.history.pushState(null, "", url);
    window.scrollTo({ top: 0, behavior: "smooth" });
  };

  const handleSignin = () => {
    setSigninOpen(false);
    setIsSignedIn(true);
    window.scrollTo({ top: 0, behavior: "smooth" });
  };

  if (isSignedIn) {
    return <Dashboard onLogout={() => setIsSignedIn(false)} />;
  }

  return (
    <div className="min-h-screen overflow-hidden bg-ink-950 text-slate-100">
      <div className="pointer-events-none fixed inset-0 bg-radial-field opacity-90" />
      <div className="pointer-events-none fixed inset-0 bg-[linear-gradient(rgba(255,255,255,0.035)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.035)_1px,transparent_1px)] bg-[size:72px_72px] opacity-20" />

      <Header
        menuOpen={menuOpen}
        setMenuOpen={setMenuOpen}
        scrollTo={scrollTo}
        openSignin={openSignin}
        openPage={openPage}
      />

      {page === "home" ? (
        <main className="relative z-10">
          <Hero scrollTo={scrollTo} openSignin={openSignin} />
          <Models />
          <Resources openPage={openPage} />
          <Pricing scrollTo={scrollTo} openSignin={openSignin} />
          <Contact />
        </main>
      ) : (
        <ResourcePage page={page} openPage={openPage} openSignin={openSignin} />
      )}

      <Footer scrollTo={scrollTo} openSignin={openSignin} openPage={openPage} />
      {signinOpen && (
        <SignInModal onClose={() => setSigninOpen(false)} onSignin={handleSignin} />
      )}
    </div>
  );
}

function getPageFromPath(): MarketingPage {
  const path = window.location.pathname.replace(/^\/+|\/+$/g, "");
  return path === "docs" || path === "about" || path === "blog" ? path : "home";
}

function getDashboardTabFromHash(): DashboardTab {
  const tab = window.location.hash.replace("#dashboard/", "");
  return tab === "voice" ||
    tab === "models" ||
    tab === "history" ||
    tab === "settings"
    ? tab
    : "overview";
}

const clonedVoicesStorageKey = "paysys-cloned-voices";
const generatedVoicesStorageKey = "paysys-generated-voices";
const voiceApiBaseUrl =
  import.meta.env.VITE_VOICE_API_BASE_URL || "http://localhost:8000";
const voiceApiToken = import.meta.env.VITE_VOICE_API_TOKEN || "";
const defaultVoiceReferenceId =
  import.meta.env.VITE_DEFAULT_VOICE_REFERENCE_ID || "voice_aad6ad520c93";
const emotionsApiPath = import.meta.env.VITE_EMOTIONS_API_PATH || "/emotions";
const googleClientId = import.meta.env.VITE_GOOGLE_CLIENT_ID || "";
const googleAuthApiPath = import.meta.env.VITE_GOOGLE_AUTH_API_PATH || "/auth/google";

function loadSavedClonedVoices(): ClonedVoice[] {
  try {
    const saved = window.localStorage.getItem(clonedVoicesStorageKey);
    return saved ? (JSON.parse(saved) as ClonedVoice[]) : [];
  } catch {
    return [];
  }
}

function saveClonedVoices(voices: ClonedVoice[]) {
  window.localStorage.setItem(clonedVoicesStorageKey, JSON.stringify(voices));
}

function loadGeneratedVoices(): GeneratedVoice[] {
  try {
    const saved = window.localStorage.getItem(generatedVoicesStorageKey);
    return saved ? (JSON.parse(saved) as GeneratedVoice[]) : [];
  } catch {
    return [];
  }
}

function saveGeneratedVoices(voices: GeneratedVoice[]) {
  window.localStorage.setItem(generatedVoicesStorageKey, JSON.stringify(voices));
}

function saveAuthSession(data: GoogleAuthResponse) {
  const token = data.access_token || data.token;
  if (token) window.localStorage.setItem("paysys-auth-token", token);
  if (data.user) window.localStorage.setItem("paysys-auth-user", JSON.stringify(data.user));
}

function decodeGoogleCredential(credential: string): GoogleProfile {
  try {
    const payload = credential.split(".")[1];
    const base64 = payload.replace(/-/g, "+").replace(/_/g, "/");
    const json = decodeURIComponent(
      window
        .atob(base64)
        .split("")
        .map((char) => `%${char.charCodeAt(0).toString(16).padStart(2, "0")}`)
        .join("")
    );
    return JSON.parse(json) as GoogleProfile;
  } catch {
    return {};
  }
}

function saveLocalGoogleSession(credential: string) {
  const profile = decodeGoogleCredential(credential);
  window.localStorage.setItem("paysys-auth-token", credential);
  window.localStorage.setItem("paysys-auth-user", JSON.stringify(profile));
}

async function authenticateWithGoogleCredential(credential: string) {
  let response: Response;
  const authUrl = `${voiceApiBaseUrl}${googleAuthApiPath}`;

  try {
    response = await fetch(authUrl, {
      method: "POST",
      headers: {
        accept: "application/json",
        "Content-Type": "application/json",
      },
      body: JSON.stringify({ credential }),
    });
  } catch {
    saveLocalGoogleSession(credential);
    return;
  }

  if (!response.ok) {
    saveLocalGoogleSession(credential);
    return;
  }

  const data = (await response.json()) as GoogleAuthResponse;
  saveAuthSession(data);
}

function resolveAudioUrl(response: AudioGenerationResponse) {
  return (
    response.audio_url ||
    response.audioUrl ||
    response.url ||
    response.file_url ||
    response.fileUrl ||
    ""
  );
}

function resolveBase64Audio(response: AudioGenerationResponse) {
  return response.audio_base64 || response.audioBase64 || response.audio || "";
}

function fileToUploadedVoice(file: File): Promise<UploadedVoice> {
  return new Promise((resolve, reject) => {
    const reader = new FileReader();
    reader.onload = () => {
      const result = String(reader.result || "");
      resolve({
        audio_base64: result.includes(",") ? result.split(",")[1] : result,
        filename: file.name,
      });
    };
    reader.onerror = () => reject(reader.error);
    reader.readAsDataURL(file);
  });
}

function normalizeEmotionList(data: EmotionListResponse) {
  const list = Array.isArray(data) ? data : data.emotions || data.data || data.results || [];
  return list.map((emotion) => String(emotion)).filter(Boolean);
}

async function fetchEmotionTypes() {
  if (!voiceApiToken) {
    throw new Error("Missing VITE_VOICE_API_TOKEN in .env");
  }

  const response = await fetch(`${voiceApiBaseUrl}${emotionsApiPath}`, {
    headers: {
      accept: "application/json",
      Authorization: `Bearer ${voiceApiToken}`,
    },
  });

  if (!response.ok) {
    throw new Error(`Emotion list API failed with ${response.status}`);
  }

  const emotions = normalizeEmotionList((await response.json()) as EmotionListResponse);
  if (emotions.length === 0) {
    throw new Error("Emotion list API returned no emotions");
  }
  return emotions;
}

function Header({
  menuOpen,
  setMenuOpen,
  scrollTo,
  openSignin,
  openPage,
}: {
  menuOpen: boolean;
  setMenuOpen: (open: boolean) => void;
  scrollTo: (id: string) => void;
  openSignin: () => void;
  openPage: (page: MarketingPage) => void;
}) {
  return (
    <header className="fixed left-0 right-0 top-0 z-50 border-b border-white/10 bg-ink-950/80 backdrop-blur-2xl">
      <nav className="mx-auto flex h-20 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
        <button
          onClick={() => openPage("home")}
          className="group flex items-center gap-3"
          aria-label="Paysys home"
        >
          <span className="grid h-10 w-10 place-items-center rounded-2xl border border-cyan-300/30 bg-cyan-300/10 text-cyan-200 shadow-glow">
            <Radio size={20} />
          </span>
          <span className="text-xl font-semibold tracking-[0.18em] text-white">
            Paysys
          </span>
        </button>

        <div className="hidden items-center gap-2 lg:flex">
          <DesktopDropdown label="Models" items={modelItems} />
          <DesktopDropdown label="Resources" items={resourceItems} openPage={openPage} />
          <NavButton onClick={() => scrollTo("#pricing")}>Pricing</NavButton>
          <NavButton onClick={() => scrollTo("#contact")}>Contact</NavButton>
          <NavButton onClick={openSignin}>Sign In</NavButton>
        </div>

        <button
          className="grid h-11 w-11 place-items-center rounded-xl border border-white/10 bg-white/5 text-white lg:hidden"
          onClick={() => setMenuOpen(!menuOpen)}
          aria-label="Toggle menu"
        >
          {menuOpen ? <X size={20} /> : <Menu size={20} />}
        </button>
      </nav>

      {menuOpen && (
        <div className="border-t border-white/10 bg-ink-900/95 px-4 py-5 backdrop-blur-xl lg:hidden">
          <MobileDropdown label="Models" items={modelItems} onNavigate={scrollTo} />
          <MobileDropdown
            label="Resources"
            items={resourceItems}
            onNavigate={(href) => {
              const key = href.replace("/", "") as MarketingPage;
              openPage(key);
            }}
          />
          <button className="mobile-nav-button" onClick={() => scrollTo("#pricing")}>
            Pricing
          </button>
          <button className="mobile-nav-button" onClick={() => scrollTo("#contact")}>
            Contact
          </button>
          <button className="mobile-nav-button" onClick={openSignin}>
            Sign In
          </button>
        </div>
      )}
    </header>
  );
}

function DesktopDropdown({
  label,
  items,
  openPage,
}: NavDropdown & {
  openPage?: (page: MarketingPage) => void;
}) {
  const [open, setOpen] = useState(false);

  return (
    <div
      className="relative"
      onMouseEnter={() => setOpen(true)}
      onMouseLeave={() => setOpen(false)}
    >
      <button className="nav-button" onClick={() => setOpen(!open)} aria-expanded={open}>
        {label}
        <ChevronDown className={`transition ${open ? "rotate-180" : ""}`} size={16} />
      </button>
      {open && (
        <div className="absolute left-0 top-full w-56 pt-3">
          <div className="rounded-2xl border border-white/10 bg-ink-900/95 p-2 shadow-panel backdrop-blur-xl">
            {items.map((item) => (
              <a
                key={item.label}
                href={item.href}
                onClick={(event) => {
                  setOpen(false);
                  if (openPage && item.href.startsWith("/")) {
                    event.preventDefault();
                    openPage(item.href.replace("/", "") as MarketingPage);
                  }
                }}
                className="block rounded-xl px-4 py-3 text-sm text-slate-300 transition hover:bg-white/10 hover:text-white"
              >
                {item.label}
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  );
}

function MobileDropdown({
  label,
  items,
  onNavigate,
}: NavDropdown & { onNavigate: (href: string) => void }) {
  const [open, setOpen] = useState(false);
  return (
    <div className="mb-2">
      <button className="mobile-nav-button" onClick={() => setOpen(!open)}>
        <span>{label}</span>
        <ChevronDown className={open ? "rotate-180" : ""} size={16} />
      </button>
      {open && (
        <div className="ml-3 mt-1 space-y-1 border-l border-white/10 pl-3">
          {items.map((item) => (
            <a
              key={item.label}
              href={item.href}
              onClick={(event) => {
                event.preventDefault();
                onNavigate(item.href);
              }}
              className="block rounded-xl px-3 py-2 text-sm text-slate-300 hover:bg-white/10 hover:text-white"
            >
              {item.label}
            </a>
          ))}
        </div>
      )}
    </div>
  );
}

function NavButton({
  children,
  onClick,
}: {
  children: ReactNode;
  onClick: () => void;
}) {
  return (
    <button className="nav-button" onClick={onClick}>
      {children}
    </button>
  );
}

function Hero({
  scrollTo,
  openSignin,
}: {
  scrollTo: (id: string) => void;
  openSignin: () => void;
}) {
  return (
    <section id="top" className="section-pad pt-32 sm:pt-36 lg:pt-40">
      <div className="mx-auto grid max-w-7xl items-center gap-12 px-4 sm:px-6 lg:grid-cols-[1.02fr_0.98fr] lg:px-8">
        <div className="max-w-3xl">
          <div className="mb-6 inline-flex items-center gap-2 rounded-full border border-cyan-300/25 bg-cyan-300/10 px-4 py-2 text-sm text-cyan-100">
            <Sparkles size={16} />
            Voice-over models for real-time business audio
          </div>
          <h1 className="text-balance text-5xl font-semibold leading-[1.02] text-white sm:text-6xl lg:text-7xl">
            Build realistic voice AI experiences with expressive control.
          </h1>
          <p className="mt-6 max-w-2xl text-lg leading-8 text-slate-300">
            Paysys helps teams generate polished voice-overs, IVR prompts,
            support prompts, product narration, and production-ready speech with
            fast, reliable voice models.
          </p>
          <div className="mt-9 flex flex-col gap-3 sm:flex-row">
            <button className="primary-button" onClick={openSignin}>
              Get Started
              <ArrowRight size={18} />
            </button>
          </div>
        </div>

        <VoiceDemoCard />
      </div>
    </section>
  );
}

function VoiceDemoCard() {
  const [active, setActive] = useState("Emotion Model");
  const [emotionType, setEmotionType] = useState("");
  const [sampleText, setSampleText] = useState(
    "Your payment confirmation is ready. This voice can sound calm, clear, and confident across every customer touchpoint."
  );
  const [isPreviewing, setIsPreviewing] = useState(false);
  const [previewAudioUrl, setPreviewAudioUrl] = useState("");
  const [previewError, setPreviewError] = useState("");
  const [emotionTypes, setEmotionTypes] = useState<string[]>([]);
  const [isLoadingEmotions, setIsLoadingEmotions] = useState(false);
  const [emotionListError, setEmotionListError] = useState("");
  const bars = [30, 54, 76, 42, 88, 62, 48, 95, 58, 72, 40, 83, 52, 68, 34, 78, 46, 90];

  const loadEmotions = async () => {
    setIsLoadingEmotions(true);
    setEmotionListError("");

    try {
      const nextEmotions = await fetchEmotionTypes();
      setEmotionTypes(nextEmotions);
      setEmotionType(nextEmotions[0]);
    } catch (error) {
      setEmotionListError(error instanceof Error ? error.message : "Unable to load emotions");
    } finally {
      setIsLoadingEmotions(false);
    }
  };

  const handlePreview = async () => {
    setIsPreviewing(true);
    setPreviewError("");

    try {
      if (!voiceApiToken) {
        throw new Error("Missing VITE_VOICE_API_TOKEN in .env");
      }

      const isEmotionModel = active === "Emotion Model";
      if (isEmotionModel && !emotionType) {
        throw new Error("Load and select an emotion first");
      }
      const endpoint = isEmotionModel
        ? "/generate-audio-emotion"
        : "/generate-audio-no-emotion";
      const payload = {
        text: sampleText,
        language: "ur",
        voice_reference_id: defaultVoiceReferenceId,
        ...(isEmotionModel ? { emotion: emotionType } : {}),
      };

      const response = await fetch(`${voiceApiBaseUrl}${endpoint}`, {
        method: "POST",
        headers: {
          accept: "application/json",
          Authorization: `Bearer ${voiceApiToken}`,
          "Content-Type": "application/json",
        },
        body: JSON.stringify(payload),
      });

      if (!response.ok) {
        throw new Error(`Audio API failed with ${response.status}`);
      }

      const contentType = response.headers.get("content-type") || "";
      let nextAudioUrl = "";
      if (contentType.includes("audio/")) {
        const blob = await response.blob();
        nextAudioUrl = URL.createObjectURL(blob);
      } else {
        const data = (await response.json()) as AudioGenerationResponse;
        const responseAudioUrl = resolveAudioUrl(data);
        const base64Audio = resolveBase64Audio(data);
        nextAudioUrl =
          responseAudioUrl || (base64Audio ? `data:audio/wav;base64,${base64Audio}` : "");
      }

      if (!nextAudioUrl) {
        throw new Error("Audio URL/base64 not found in API response");
      }

      setPreviewAudioUrl(nextAudioUrl);
      await new Audio(nextAudioUrl).play();
    } catch (error) {
      setPreviewError(error instanceof Error ? error.message : "Audio preview failed");
    } finally {
      setIsPreviewing(false);
    }
  };

  return (
    <div className="relative">
      <div className="absolute -inset-4 rounded-[2rem] bg-cyan-400/10 blur-3xl" />
      <div className="relative rounded-[2rem] border border-white/10 bg-white/10 p-5 shadow-panel backdrop-blur-2xl sm:p-6">
        <div className="mb-5 flex items-center justify-between gap-4">
          <div>
            <p className="text-sm text-slate-400">Live voice preview</p>
            <h2 className="mt-1 text-2xl font-semibold text-white">Studio Console</h2>
          </div>
        </div>

        <div className="rounded-3xl border border-white/10 bg-ink-950/70 p-4">
          <div className="mb-4 flex flex-wrap gap-2">
            {["Emotion Model", "No Emotion Model"].map((item) => (
              <button
                key={item}
                onClick={() => setActive(item)}
                className={`rounded-full px-4 py-2 text-sm transition ${
                  active === item
                    ? "bg-cyan-300 text-ink-950"
                    : "bg-white/10 text-slate-300 hover:bg-white/20"
                }`}
              >
                {item}
              </button>
            ))}
          </div>

          {active === "Emotion Model" ? (
            <div className="mb-4 rounded-2xl border border-cyan-300/15 bg-cyan-300/10 p-3">
              <p className="text-xs font-semibold uppercase tracking-[0.18em] text-cyan-200">
                Emotion type
              </p>
              <button
                className="mt-3 rounded-full border border-cyan-300/30 bg-ink-950/70 px-3 py-1.5 text-xs font-semibold text-cyan-100 transition hover:bg-white/10 disabled:opacity-60"
                onClick={loadEmotions}
                disabled={isLoadingEmotions}
                type="button"
              >
                {isLoadingEmotions ? "Loading emotions..." : "Load emotions"}
              </button>
              {emotionListError && (
                <p className="mt-2 text-xs leading-5 text-red-200">{emotionListError}</p>
              )}
              {emotionTypes.length > 0 && (
                <div className="mt-3 flex flex-wrap gap-2">
                  {emotionTypes.map((type) => (
                    <button
                      key={type}
                      onClick={() => setEmotionType(type)}
                      className={`rounded-full px-3 py-1.5 text-xs font-semibold transition ${
                        emotionType === type
                          ? "bg-cyan-300 text-ink-950"
                          : "bg-white/10 text-slate-300 hover:bg-white/20"
                      }`}
                    >
                      {type}
                    </button>
                  ))}
                </div>
              )}
            </div>
          ) : (
            <div className="mb-4 rounded-2xl border border-white/10 bg-white/5 p-3">
              <p className="text-xs font-semibold uppercase tracking-[0.18em] text-slate-300">
                Neutral mode
              </p>
              <p className="mt-2 text-xs leading-5 text-slate-400">
                Emotion controls are disabled for standard narration and IVR output.
              </p>
            </div>
          )}

          <div className="flex h-36 items-center gap-2 rounded-2xl bg-[linear-gradient(135deg,rgba(59,167,255,0.12),rgba(141,108,255,0.08))] px-4">
            {bars.map((height, index) => (
              <span
                key={index}
                className="w-full rounded-full bg-gradient-to-t from-cyan-300 to-violet-300 opacity-90 transition duration-300 hover:opacity-100"
                style={{ height: `${height}%` }}
              />
            ))}
          </div>

          <div className="mt-5 rounded-2xl border border-white/10 bg-white/10 p-4">
            <div className="flex items-center justify-between gap-3">
              <label className="text-xs uppercase tracking-[0.2em] text-cyan-200">
                Sample text
              </label>
              <button
                className="grid h-10 w-10 shrink-0 place-items-center rounded-full bg-cyan-300 text-ink-950 shadow-glow transition hover:scale-105 disabled:cursor-not-allowed disabled:opacity-60"
                aria-label="Preview voice"
                disabled={isPreviewing}
                onClick={handlePreview}
              >
                {isPreviewing ? <Activity size={18} /> : <Play size={18} fill="currentColor" />}
              </button>
            </div>
            <textarea
              className="mt-3 min-h-24 w-full resize-none rounded-2xl border border-white/10 bg-ink-950/70 p-3 text-sm leading-6 text-slate-100 outline-none transition placeholder:text-slate-600 focus:border-cyan-300/70 focus:ring-4 focus:ring-cyan-300/10"
              value={sampleText}
              onChange={(event) => setSampleText(event.target.value)}
              placeholder="Write text to preview voice..."
            />
            {previewError && (
              <p className="mt-3 text-xs leading-5 text-red-200">{previewError}</p>
            )}
            {previewAudioUrl && (
              <audio className="mt-3 w-full" controls src={previewAudioUrl}>
                <track kind="captions" />
              </audio>
            )}
          </div>
        </div>

        <div className="mt-5 grid grid-cols-3 gap-3">
          <MiniMetric label="Latency" value="48 ms" />
          <MiniMetric label="Quality" value="HD" />
          <MiniMetric label="Stream" value="Live" />
        </div>
      </div>
    </div>
  );
}

function MiniMetric({ label, value }: { label: string; value: string }) {
  return (
    <div className="min-w-0 rounded-2xl border border-white/10 bg-white/10 p-3 text-center">
      <p className="break-words text-sm font-semibold leading-tight text-white sm:text-base">
        {value}
      </p>
      <p className="mt-1 text-xs text-slate-400">{label}</p>
    </div>
  );
}

