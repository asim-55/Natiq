function Dashboard({ onLogout }: { onLogout: () => void }) {
  const [activeTab, setActiveTab] = useState<DashboardTab>(() => getDashboardTabFromHash());
  const [activeModel, setActiveModel] = useState("Emotion Model");
  const [emotionType, setEmotionType] = useState("");
  const [voiceScript, setVoiceScript] = useState(
    "Welcome to Paysys. Your secure banking voice flow is ready for real-time playback."
  );
  const [voiceCloneEnabled, setVoiceCloneEnabled] = useState(false);
  const [cloneVoiceName, setCloneVoiceName] = useState("Relationship Manager");
  const [sampleVoiceFileName, setSampleVoiceFileName] = useState("");
  const [sampleVoiceBase64, setSampleVoiceBase64] = useState("");
  const [cloneConsent, setCloneConsent] = useState(false);
  const [savedClonedVoices, setSavedClonedVoices] = useState<ClonedVoice[]>(() =>
    loadSavedClonedVoices()
  );
  const [generatedVoices, setGeneratedVoices] = useState<GeneratedVoice[]>(() =>
    loadGeneratedVoices()
  );
  const [selectedCloneId, setSelectedCloneId] = useState("");
  const [isGenerating, setIsGenerating] = useState(false);
  const [hasResult, setHasResult] = useState(true);
  const [isPlaying, setIsPlaying] = useState(false);
  const [audioUrl, setAudioUrl] = useState("");
  const [generationError, setGenerationError] = useState("");
  const [emotionTypes, setEmotionTypes] = useState<string[]>([]);
  const [isLoadingEmotions, setIsLoadingEmotions] = useState(false);
  const [emotionListError, setEmotionListError] = useState("");
  const demoJobs: GeneratedVoice[] = [
    {
      id: "demo-bank-ivr",
      title: "Bank IVR greeting",
      model: "Emotion Model",
      voice: "Default",
      duration: "18 sec",
      status: "Ready",
      createdAt: "Demo",
    },
    {
      id: "demo-loan-update",
      title: "Loan approval update",
      model: "No Emotion Model",
      voice: "Default",
      duration: "31 sec",
      status: "Ready",
      createdAt: "Demo",
    },
    {
      id: "demo-product-intro",
      title: "Product demo intro",
      model: "Emotion Model",
      voice: "Default",
      duration: "46 sec",
      status: "Processing",
      createdAt: "Demo",
    },
  ];
  const visibleJobs = generatedVoices.length > 0 ? generatedVoices : demoJobs;

  useEffect(() => {
    const handlePopState = () => setActiveTab(getDashboardTabFromHash());
    window.addEventListener("popstate", handlePopState);
    return () => window.removeEventListener("popstate", handlePopState);
  }, []);

  const openTab = (tab: DashboardTab) => {
    setActiveTab(tab);
    window.history.pushState(null, "", `#dashboard/${tab}`);
    window.scrollTo({ top: 0, behavior: "smooth" });
  };

  const loadEmotions = async () => {
    setIsLoadingEmotions(true);
    setEmotionListError("");

    try {
      const nextEmotions = await fetchEmotionTypes();
      setEmotionTypes(nextEmotions);
      setEmotionType(nextEmotions[0]);
    } catch (error) {
      setEmotionListError(error instanceof Error ? error.message : "Unable to load emotions");
    } finally {
      setIsLoadingEmotions(false);
    }
  };

  const saveGenerationRecord = (audio?: string) => {
    const selectedVoice = savedClonedVoices.find((voice) => voice.id === selectedCloneId);
    const generatedVoice: GeneratedVoice = {
      id: `generation-${Date.now()}`,
      title: voiceScript.trim().slice(0, 42) || "Untitled voice generation",
      model: activeModel,
      voice: voiceCloneEnabled ? selectedVoice?.name || cloneVoiceName || "Cloned voice" : "Default",
      duration: `${Math.max(6, Math.ceil(voiceScript.trim().length / 8))} sec`,
      status: "Ready",
      createdAt: new Date().toLocaleDateString(),
    };
    const nextGenerations = [generatedVoice, ...generatedVoices];
    setGeneratedVoices(nextGenerations);
    saveGeneratedVoices(nextGenerations);
    if (audio) setAudioUrl(audio);
  };

  const handleGenerate = async () => {
    setIsGenerating(true);
    setHasResult(false);
    setIsPlaying(false);
    setGenerationError("");

    try {
      if (!voiceApiToken) {
        throw new Error("Missing VITE_VOICE_API_TOKEN in .env");
      }

      const selectedVoice = savedClonedVoices.find((voice) => voice.id === selectedCloneId);
      const selectedVoiceReferenceId =
        selectedVoice?.id.startsWith("voice_") ? selectedVoice.id : defaultVoiceReferenceId;
      const isEmotionModel = activeModel === "Emotion Model";
      if (isEmotionModel && !emotionType) {
        throw new Error("Load and select an emotion first");
      }
      const endpoint = isEmotionModel
        ? "/generate-audio-emotion"
        : "/generate-audio-no-emotion";
      const payload = {
        text: voiceScript,
        language: "ur",
        voice_reference_id: voiceCloneEnabled
          ? selectedVoiceReferenceId
          : defaultVoiceReferenceId,
        ...(isEmotionModel ? { emotion: emotionType } : {}),
      };

      const response = await fetch(`${voiceApiBaseUrl}${endpoint}`, {
        method: "POST",
        headers: {
          accept: "application/json",
          Authorization: `Bearer ${voiceApiToken}`,
          "Content-Type": "application/json",
        },
        body: JSON.stringify(payload),
      });

      if (!response.ok) {
        throw new Error(`Audio API failed with ${response.status}`);
      }

      const contentType = response.headers.get("content-type") || "";
      if (contentType.includes("audio/")) {
        const blob = await response.blob();
        saveGenerationRecord(URL.createObjectURL(blob));
      } else {
        const data = (await response.json()) as AudioGenerationResponse;
        const responseAudioUrl = resolveAudioUrl(data);
        const base64Audio = resolveBase64Audio(data);
        saveGenerationRecord(
          responseAudioUrl || (base64Audio ? `data:audio/wav;base64,${base64Audio}` : "")
        );
      }
      setIsGenerating(false);
      setHasResult(true);
    } catch (error) {
      setGenerationError(error instanceof Error ? error.message : "Audio generation failed");
      setIsGenerating(false);
      setHasResult(false);
    }
  };

  const handleSaveClonedVoice = () => {
    if (!cloneVoiceName.trim() || !sampleVoiceFileName || !sampleVoiceBase64 || !cloneConsent) return;

    const clonedVoice: ClonedVoice = {
      id: `voice-${Date.now()}`,
      name: cloneVoiceName.trim(),
      sampleFileName: sampleVoiceFileName,
      audioBase64: sampleVoiceBase64,
      createdAt: new Date().toLocaleDateString(),
    };
    const nextVoices = [clonedVoice, ...savedClonedVoices];
    setSavedClonedVoices(nextVoices);
    setSelectedCloneId(clonedVoice.id);
    saveClonedVoices(nextVoices);
  };

  const handleSelectClonedVoice = (voiceId: string) => {
    setSelectedCloneId(voiceId);
    const voice = savedClonedVoices.find((item) => item.id === voiceId);
    if (!voice) return;
    setVoiceCloneEnabled(true);
    setCloneVoiceName(voice.name);
    setSampleVoiceFileName(voice.sampleFileName);
    setSampleVoiceBase64(voice.audioBase64);
    setCloneConsent(true);
  };

  const handleSampleVoiceUpload = async (file: File | undefined) => {
    if (!file) return;
    const uploadedVoice = await fileToUploadedVoice(file);
    setSampleVoiceFileName(uploadedVoice.filename);
    setSampleVoiceBase64(uploadedVoice.audio_base64);
  };

  return (
    <div className="min-h-screen bg-ink-950 text-slate-100">
      <div className="pointer-events-none fixed inset-0 bg-radial-field opacity-70" />
      <div className="relative z-10 flex min-h-screen">
        <aside className="hidden w-72 shrink-0 border-r border-white/10 bg-ink-900/75 p-5 backdrop-blur-2xl lg:block">
          <button
            className="flex items-center gap-3 px-2"
            onClick={onLogout}
            aria-label="Go to Paysys landing page"
          >
            <span className="grid h-10 w-10 place-items-center rounded-2xl border border-cyan-300/30 bg-cyan-300/10 text-cyan-200">
              <Radio size={20} />
            </span>
            <span className="text-xl font-semibold tracking-[0.18em] text-white">
              Paysys
            </span>
          </button>

          <div className="mt-8 space-y-2">
            <DashboardNavItem icon={<Home size={18} />} label="Overview" active={activeTab === "overview"} onClick={() => openTab("overview")} />
            <DashboardNavItem icon={<Mic2 size={18} />} label="Text to Voice" active={activeTab === "voice"} onClick={() => openTab("voice")} />
            <DashboardNavItem icon={<Layers3 size={18} />} label="Models" active={activeTab === "models"} onClick={() => openTab("models")} />
            <DashboardNavItem icon={<Clock3 size={18} />} label="History" active={activeTab === "history"} onClick={() => openTab("history")} />
            <DashboardNavItem icon={<Settings size={18} />} label="Settings" active={activeTab === "settings"} onClick={() => openTab("settings")} />
          </div>

          <div className="mt-8 rounded-3xl border border-cyan-300/20 bg-cyan-300/10 p-4">
            <p className="text-sm font-semibold text-white">Business plan</p>
            <p className="mt-2 text-sm leading-6 text-cyan-50">
              72% monthly voice credits used. Upgrade anytime for higher volume.
            </p>
            <div className="mt-4 h-2 rounded-full bg-white/10">
              <div className="h-full w-[72%] rounded-full bg-cyan-300" />
            </div>
          </div>
        </aside>

        <div className="flex min-w-0 flex-1 flex-col">
          <header className="sticky top-0 z-20 border-b border-white/10 bg-ink-950/80 px-4 py-4 backdrop-blur-2xl sm:px-6 lg:px-8">
            <div className="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
              <div>
                <button
                  className="flex items-center gap-3 lg:hidden"
                  onClick={onLogout}
                  aria-label="Go to Paysys landing page"
                >
                  <span className="grid h-10 w-10 place-items-center rounded-2xl border border-cyan-300/30 bg-cyan-300/10 text-cyan-200">
                    <Radio size={20} />
                  </span>
                  <span className="text-lg font-semibold tracking-[0.18em] text-white">
                    Paysys
                  </span>
                </button>
                <p className="mt-3 text-sm text-cyan-200 lg:mt-0">Text-to-Voice Console</p>
                <h1 className="mt-1 text-2xl font-semibold text-white sm:text-3xl">
                  Generate voice-overs from text
                </h1>
              </div>
              <div className="flex flex-col gap-3 sm:flex-row sm:items-center">
                <div className="flex min-w-0 items-center gap-2 rounded-full border border-white/10 bg-white/10 px-4 py-3 text-sm text-slate-400 sm:w-72">
                  <Search size={16} />
                  <span>Search voices, jobs, docs</span>
                </div>
                <button className="secondary-button px-5 py-3" onClick={onLogout}>
                  <LogOut size={17} />
                  Logout
                </button>
              </div>
            </div>
          </header>

          <main className="space-y-6 p-4 sm:p-6 lg:p-8">
            <div className="grid grid-cols-2 gap-2 sm:grid-cols-5 lg:hidden">
              <MobileDashButton icon={<Home size={17} />} label="Home" active={activeTab === "overview"} onClick={() => openTab("overview")} />
              <MobileDashButton icon={<Mic2 size={17} />} label="Voice" active={activeTab === "voice"} onClick={() => openTab("voice")} />
              <MobileDashButton icon={<Layers3 size={17} />} label="Models" active={activeTab === "models"} onClick={() => openTab("models")} />
              <MobileDashButton icon={<Clock3 size={17} />} label="History" active={activeTab === "history"} onClick={() => openTab("history")} />
              <MobileDashButton icon={<Settings size={17} />} label="Settings" active={activeTab === "settings"} onClick={() => openTab("settings")} />
            </div>

            {activeTab === "overview" && (
              <div className="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
                <DashboardMetric title="Saved voices" value={String(savedClonedVoices.length)} detail="Stored in this browser" icon={<Users />} />
                <DashboardMetric title="Generated voices" value={String(generatedVoices.length)} detail="Stored in this browser" icon={<Clock3 />} />
                <DashboardMetric title="Active models" value="2" detail="Emotion and neutral" icon={<Layers3 />} />
              </div>
            )}

            {(activeTab === "overview" || activeTab === "voice") && (
              <div className="grid gap-6">
                <section className="dashboard-panel p-5 sm:p-6">
                <div className="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
                  <div>
                    <p className="text-sm text-cyan-200">Playground</p>
                    <h2 className="mt-1 text-2xl font-semibold text-white">
                      Text to voice
                    </h2>
                  </div>
                  <div className="flex rounded-full border border-white/10 bg-ink-950/70 p-1">
                    {["Emotion Model", "No Emotion Model"].map((model) => (
                      <button
                        key={model}
                        onClick={() => setActiveModel(model)}
                        className={`rounded-full px-4 py-2 text-sm transition ${
                          activeModel === model
                            ? "bg-cyan-300 text-ink-950"
                            : "text-slate-300 hover:bg-white/10"
                        }`}
                      >
                        {model}
                      </button>
                    ))}
                  </div>
                </div>

                <div className="mt-6 grid gap-5 lg:grid-cols-[0.9fr_1.1fr]">
                  <div className="rounded-3xl border border-white/10 bg-ink-950/70 p-4">
                    <label className="text-sm font-medium text-slate-300">
                      Voice script
                    </label>
                    <textarea
                      className="mt-3 min-h-56 w-full resize-none rounded-2xl border border-white/10 bg-white/10 p-4 text-sm leading-7 text-white outline-none placeholder:text-slate-600 focus:border-cyan-300/70 focus:ring-4 focus:ring-cyan-300/10"
                      value={voiceScript}
                      onChange={(event) => setVoiceScript(event.target.value)}
                    />
                    <div className="mt-4 flex flex-col gap-3 sm:flex-row">
                      <button className="primary-button flex-1" onClick={handleGenerate}>
                        {isGenerating ? <Activity size={18} /> : <Play size={18} fill="currentColor" />}
                        {isGenerating ? "Generating..." : "Generate voice"}
                      </button>
                      <button className="secondary-button flex-1">
                        <Upload size={18} />
                        Import text
                      </button>
                    </div>
                    <div className="mt-5 rounded-3xl border border-white/10 bg-white/5 p-4">
                      <div className="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
                        <div>
                          <p className="text-sm font-medium text-white">Voice cloning</p>
                          <p className="mt-1 text-sm leading-6 text-slate-400">
                            Add a consented reference voice and generate this script in that voice.
                          </p>
                        </div>
                        <button
                          className={`inline-flex items-center justify-center rounded-full px-4 py-2 text-sm font-semibold transition ${
                            voiceCloneEnabled
                              ? "bg-cyan-300 text-ink-950"
                              : "bg-white/10 text-slate-300 hover:bg-white/20"
                          }`}
                          onClick={() => setVoiceCloneEnabled(!voiceCloneEnabled)}
                          type="button"
                        >
                          {voiceCloneEnabled ? "Enabled" : "Enable"}
                        </button>
                      </div>
                      {voiceCloneEnabled && (
                        <div className="mt-4 grid gap-4 lg:grid-cols-[1fr_0.9fr]">
                          <label>
                            <span className="mb-2 block text-sm font-medium text-slate-300">
                              Clone voice name
                            </span>
                            <input
                              className="input-field"
                              value={cloneVoiceName}
                              onChange={(event) => setCloneVoiceName(event.target.value)}
                              placeholder="Enter voice name"
                            />
                          </label>
                          <label className="flex cursor-pointer items-center justify-center gap-3 rounded-2xl border border-dashed border-cyan-300/30 bg-cyan-300/10 px-4 py-4 text-sm font-semibold text-cyan-100 transition hover:bg-cyan-300/15">
                            <Upload size={18} />
                            {sampleVoiceFileName || "Upload sample audio"}
                            <input
                              className="sr-only"
                              type="file"
                              accept="audio/*"
                              onChange={(event) => handleSampleVoiceUpload(event.target.files?.[0])}
                            />
                          </label>
                          <label className="flex items-start gap-3 rounded-2xl border border-white/10 bg-ink-950/70 p-4 lg:col-span-2">
                            <input
                              className="mt-1 h-4 w-4 accent-cyan-300"
                              type="checkbox"
                              checked={cloneConsent}
                              onChange={(event) => setCloneConsent(event.target.checked)}
                            />
                            <span className="text-sm leading-6 text-slate-300">
                              I have permission to clone and use this reference voice.
                            </span>
                          </label>
                          <button
                            className="primary-button lg:col-span-2"
                            type="button"
                            onClick={handleSaveClonedVoice}
                            disabled={!cloneVoiceName.trim() || !sampleVoiceFileName || !sampleVoiceBase64 || !cloneConsent}
                          >
                            <Check size={18} />
                            Save cloned voice
                          </button>
                          {savedClonedVoices.length > 0 && (
                            <div className="rounded-2xl border border-white/10 bg-ink-950/70 p-4 lg:col-span-2">
                              <p className="text-sm font-medium text-white">Saved voices</p>
                              <div className="mt-3 grid gap-2">
                                {savedClonedVoices.map((voice) => (
                                  <button
                                    key={voice.id}
                                    className={`rounded-2xl border px-4 py-3 text-left transition ${
                                      selectedCloneId === voice.id
                                        ? "border-cyan-300/50 bg-cyan-300/10 text-white"
                                        : "border-white/10 bg-white/5 text-slate-300 hover:bg-white/10"
                                    }`}
                                    type="button"
                                    onClick={() => handleSelectClonedVoice(voice.id)}
                                  >
                                    <span className="block text-sm font-semibold">{voice.name}</span>
                                    <span className="mt-1 block text-xs text-slate-400">
                                      {voice.sampleFileName} - saved {voice.createdAt}
                                    </span>
                                  </button>
                                ))}
                              </div>
                            </div>
                          )}
                        </div>
                      )}
                    </div>
                  </div>

                  <div className="rounded-3xl border border-white/10 bg-white/10 p-4">
                    <div className="mb-4 flex items-center justify-between">
                      <div>
                        <p className="text-sm text-slate-400">Selected model</p>
                        <h3 className="mt-1 text-xl font-semibold text-white">
                          {activeModel}
                        </h3>
                      </div>
                      <SlidersHorizontal className="text-cyan-200" />
                    </div>
                    {activeModel === "Emotion Model" ? (
                      <div className="mb-5 rounded-3xl border border-cyan-300/15 bg-cyan-300/10 p-4">
                        <p className="text-sm font-medium text-white">Emotion type</p>
                        <button
                          className="mt-3 rounded-full border border-cyan-300/30 bg-ink-950/70 px-3 py-2 text-xs font-semibold text-cyan-100 transition hover:bg-white/10 disabled:opacity-60"
                          onClick={loadEmotions}
                          disabled={isLoadingEmotions}
                          type="button"
                        >
                          {isLoadingEmotions ? "Loading emotions..." : "Load emotions"}
                        </button>
                        {emotionListError && (
                          <p className="mt-2 text-xs leading-5 text-red-200">{emotionListError}</p>
                        )}
                        {emotionTypes.length > 0 && (
                          <div className="mt-3 flex flex-wrap gap-2">
                            {emotionTypes.map((type) => (
                              <button
                                key={type}
                                onClick={() => setEmotionType(type)}
                                className={`rounded-full px-3 py-2 text-xs font-semibold transition ${
                                  emotionType === type
                                    ? "bg-cyan-300 text-ink-950"
                                    : "bg-white/10 text-slate-300 hover:bg-white/20"
                                }`}
                              >
                                {type}
                              </button>
                            ))}
                          </div>
                        )}
                      </div>
                    ) : (
                      <div className="mb-5 rounded-3xl border border-white/10 bg-ink-950/70 p-4">
                        <p className="text-sm font-medium text-white">Neutral delivery</p>
                        <p className="mt-1 text-sm text-slate-400">
                          Emotion controls are disabled for clean IVR, robotic,
                          announcement, and standard narration output.
                        </p>
                      </div>
                    )}
                    <WavePreview muted={!hasResult} />
                    <div className="mt-5 grid gap-3 sm:grid-cols-3">
                      <MiniMetric label="Tone" value={activeModel === "Emotion Model" ? emotionType || "Select" : "Neutral"} />
                      <MiniMetric label="Voice" value={voiceCloneEnabled ? cloneVoiceName || "Clone" : "Default"} />
                      <MiniMetric label="Speed" value="1.0x" />
                    </div>
                    <AudioResult
                      hasResult={hasResult}
                      isGenerating={isGenerating}
                      isPlaying={isPlaying}
                      setIsPlaying={setIsPlaying}
                      audioUrl={audioUrl}
                      error={generationError}
                    />
                    <div className="mt-5 flex flex-col gap-3 sm:flex-row">
                      <button className="secondary-button flex-1">
                        <Copy size={18} />
                        Copy text
                      </button>
                      <button className="secondary-button flex-1">
                        <Download size={18} />
                        Download
                      </button>
                    </div>
                  </div>
                </div>
                </section>
              </div>
            )}

            {(activeTab === "overview" || activeTab === "models") && (
              <DashboardModelsPage />
            )}

            {(activeTab === "overview" || activeTab === "history") && (
              <div className="grid gap-6">
                <section className="dashboard-panel p-5 sm:p-6">
                <div className="flex items-center justify-between">
                  <div>
                    <p className="text-sm text-cyan-200">Recent jobs</p>
                    <h2 className="mt-1 text-2xl font-semibold text-white">
                      Generation history
                    </h2>
                  </div>
                  <Clock3 className="text-cyan-200" />
                </div>
                <div className="mt-5 overflow-hidden rounded-3xl border border-white/10">
                  {visibleJobs.map((job) => (
                    <div
                      key={job.id}
                      className="grid gap-2 border-b border-white/10 bg-white/5 p-4 text-sm last:border-b-0 sm:grid-cols-[1fr_0.8fr_0.8fr_0.5fr_0.6fr]"
                    >
                      <span className="font-medium text-white">{job.title}</span>
                      <span className="text-slate-400">{job.model}</span>
                      <span className="text-slate-400">{job.voice}</span>
                      <span className="text-slate-400">{job.duration}</span>
                      <span className={job.status === "Ready" ? "text-cyan-200" : "text-violet-200"}>
                        {job.status}
                      </span>
                    </div>
                  ))}
                </div>
                </section>
              </div>
            )}

            {activeTab === "settings" && <DashboardSettingsPage onLogout={onLogout} />}
          </main>
        </div>
      </div>
    </div>
  );
}

function DashboardNavItem({
  icon,
  label,
  active = false,
  onClick,
}: {
  icon: ReactNode;
  label: string;
  active?: boolean;
  onClick: () => void;
}) {
  return (
    <button
      onClick={onClick}
      className={`flex w-full items-center gap-3 rounded-2xl px-4 py-3 text-sm font-medium transition ${
        active
          ? "bg-cyan-300 text-ink-950"
          : "text-slate-300 hover:bg-white/10 hover:text-white"
      }`}
    >
      {icon}
      {label}
    </button>
  );
}

function MobileDashButton({
  icon,
  label,
  active = false,
  onClick,
}: {
  icon: ReactNode;
  label: string;
  active?: boolean;
  onClick: () => void;
}) {
  return (
    <button
      onClick={onClick}
      className={`flex min-h-16 flex-col items-center justify-center gap-1 rounded-2xl border text-xs font-medium transition ${
        active
          ? "border-cyan-300/40 bg-cyan-300 text-ink-950"
          : "border-white/10 bg-white/10 text-slate-300"
      }`}
    >
      {icon}
      {label}
    </button>
  );
}

function DashboardMetric({
  title,
  value,
  detail,
  icon,
}: {
  title: string;
  value: string;
  detail: string;
  icon: ReactNode;
}) {
  return (
    <div className="dashboard-panel p-5">
      <div className="flex items-center justify-between">
        <p className="text-sm text-slate-400">{title}</p>
        <span className="text-cyan-200">{icon}</span>
      </div>
      <p className="mt-5 text-3xl font-semibold text-white">{value}</p>
      <p className="mt-2 text-sm text-slate-400">{detail}</p>
    </div>
  );
}

function DashboardModelsPage() {
  return (
    <section className="dashboard-panel p-5 sm:p-6">
      <div className="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <p className="text-sm text-cyan-200">Model catalog</p>
          <h2 className="mt-1 text-2xl font-semibold text-white">Available voice models</h2>
        </div>
        <span className="rounded-full border border-white/10 bg-white/10 px-4 py-2 text-sm text-slate-300">
          2 active models
        </span>
      </div>
      <div className="mt-6 grid gap-5 lg:grid-cols-2">
        <ModelDetailCard
          title="Emotion Model"
          description="Expressive voice-over output with selectable emotional delivery."
          tags={["Backend emotion list", "Selectable delivery", "Urdu generation", "Voice reference"]}
        />
        <ModelDetailCard
          title="No Emotion Model"
          description="Clean neutral voice output for IVR, announcements, robotic reads, and standard narration."
          tags={["Neutral", "IVR", "Announcement", "Narration", "Robotic"]}
        />
      </div>
    </section>
  );
}

