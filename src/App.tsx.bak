      <div className="mt-6 grid gap-5 lg:grid-cols-[1fr_0.8fr]">
        <div className="rounded-3xl border border-white/10 bg-ink-950/70 p-5">
          <div className="flex items-center justify-between text-sm">
            <span className="text-slate-300">Characters used</span>
            <span className="font-semibold text-white">1.28M / 2M</span>
          </div>
          <div className="mt-3 h-3 rounded-full bg-white/10">
            <div className="h-full w-[64%] rounded-full bg-gradient-to-r from-cyan-300 to-violet-300" />
          </div>
          <div className="mt-6 grid gap-3 sm:grid-cols-3">
            <MiniMetric label="Remaining" value="720K" />
            <MiniMetric label="Generations" value="148" />
