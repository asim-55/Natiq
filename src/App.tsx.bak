      <h2 className="mt-1 text-2xl font-semibold text-white">Account preferences</h2>
      <div className="mt-6 grid gap-5 lg:grid-cols-2">
        <div className="rounded-3xl border border-white/10 bg-ink-950/70 p-5">
          <h3 className="text-xl font-semibold text-white">Profile</h3>
          <Field label="Name" placeholder="Paysys User" />
          <Field label="Email" placeholder="user@company.com" type="email" />
          <button className="secondary-button mt-5 w-full">Save changes</button>
        </div>
        <div className="rounded-3xl border border-white/10 bg-white/5 p-5">
          <h3 className="text-xl font-semibold text-white">Security</h3>
          <p className="mt-3 text-sm leading-6 text-slate-400">
            Password, Google login, and session controls will become active
            when authentication APIs are connected.
          </p>
          <button className="secondary-button mt-5 w-full" onClick={onLogout}>
            <LogOut size={18} />
            Logout
          </button>
        </div>
