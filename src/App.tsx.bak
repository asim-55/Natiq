function HealthBar({
  label,
  value,
  width,
  tone,
}: {
  label: string;
  value: string;
  width: string;
  tone: "cyan" | "violet" | "lime" | "blue";
}) {
  const toneClass = {
    cyan: "from-cyan-300 to-teal-300",
    violet: "from-violet-300 to-fuchsia-300",
    lime: "from-lime-300 to-cyan-300",
    blue: "from-blue-300 to-cyan-300",
  }[tone];

  return (
    <div className="mb-5">
      <div className="mb-2 flex items-center justify-between text-sm">
        <span className="text-slate-300">{label}</span>
        <span className="font-semibold text-white">{value}</span>
      </div>
      <div className="h-3 overflow-hidden rounded-full bg-white/10">
        <div className={`h-full rounded-full bg-gradient-to-r ${toneClass}`} style={{ width }} />
      </div>
    </div>
  );
}

